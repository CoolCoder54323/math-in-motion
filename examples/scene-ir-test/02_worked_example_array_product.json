{
  "scenes": [
    {
      "sceneId": "worked_example_array_product",
      "sceneIR": {
        "metadata": {
          "sceneId": "worked_example_array_product",
          "role": "worked_example",
          "visualIntent": "Use arrays to connect repeated addition to multiplication in one clear progression.",
          "densityTarget": 0.44,
          "baseClass": "Scene"
        },
        "layout": {
          "safeArea": {
            "xMin": -6.5,
            "xMax": 6.5,
            "yMin": -3.5,
            "yMax": 3.5
          },
          "zones": [
            { "id": "title", "x": 0, "y": 2.8, "width": 11, "height": 1.0, "note": "Title lane" },
            { "id": "hero", "x": 0, "y": 0.6, "width": 8.2, "height": 4.1, "note": "Array and equation" },
            { "id": "left", "x": -3.4, "y": 0.4, "width": 3.0, "height": 3.4, "note": "Row labels" },
            { "id": "right", "x": 3.5, "y": 0.4, "width": 3.0, "height": 3.4, "note": "Result card" },
            { "id": "footer", "x": 0, "y": -2.7, "width": 11, "height": 1.1, "note": "Takeaway lane" }
          ],
          "continuitySlots": ["array_model", "equation_final"]
        },
        "objects": [
          {
            "id": "title",
            "kind": "text",
            "role": "scene_title",
            "anchor": { "zone": "title", "align": "center" },
            "props": { "text": "3 x 4 as an Array", "fontSize": 50 },
            "relatedTo": [],
            "zIndex": 4
          },
          {
            "id": "array_model",
            "kind": "compound.array_grid",
            "role": "main_array",
            "anchor": { "zone": "hero", "align": "center", "dy": 0.25 },
            "props": {
              "rows": 3,
              "cols": 4,
              "cellSize": 0.62,
              "highlighted": [
                [0, 0], [0, 1], [0, 2], [0, 3],
                [1, 0], [1, 1], [1, 2], [1, 3],
                [2, 0], [2, 1], [2, 2], [2, 3]
              ]
            },
            "relatedTo": ["equation_partial", "equation_final"],
            "zIndex": 2
          },
          {
            "id": "equation_partial",
            "kind": "math",
            "role": "partial_expression",
            "anchor": { "zone": "hero", "align": "bottom", "dy": -0.1 },
            "props": { "tex": "3 \\times 4", "scale": 1.3 },
            "relatedTo": ["equation_final"],
            "zIndex": 3
          },
          {
            "id": "equation_final",
            "kind": "math",
            "role": "final_expression",
            "anchor": { "zone": "hero", "align": "bottom", "dy": -0.1 },
            "props": { "tex": "3 \\times 4 = 12", "scale": 1.3 },
            "relatedTo": ["equation_partial"],
            "zIndex": 3
          },
          {
            "id": "result_card",
            "kind": "compound.callout_card",
            "role": "result_summary",
            "anchor": { "zone": "right", "align": "center" },
            "props": {
              "title": "Total Tiles",
              "body": "12",
              "width": 2.6,
              "height": 1.8,
              "fillColor": "#DFF3FF"
            },
            "relatedTo": ["equation_final"],
            "zIndex": 4
          },
          {
            "id": "takeaway",
            "kind": "text",
            "role": "footer_takeaway",
            "anchor": { "zone": "footer", "align": "center" },
            "props": { "text": "Rows x columns gives the total.", "fontSize": 30 },
            "relatedTo": [],
            "zIndex": 5
          }
        ],
        "beats": [
          {
            "id": "setup",
            "narration": "We can visualize multiplication as rows and columns.",
            "actions": [
              { "type": "show", "targets": ["title"], "animation": "write", "runTime": 0.8 },
              { "type": "show", "targets": ["array_model"], "animation": "create", "runTime": 1.1 }
            ],
            "holdSeconds": 0.3
          },
          {
            "id": "symbolic_link",
            "narration": "This array has three rows of four tiles each.",
            "actions": [
              { "type": "show", "targets": ["equation_partial"], "animation": "write", "runTime": 0.7 },
              { "type": "emphasize", "targets": ["array_model"], "animation": "indicate", "runTime": 0.6 }
            ],
            "holdSeconds": 0.3
          },
          {
            "id": "solve",
            "narration": "So 3 times 4 equals 12.",
            "actions": [
              { "type": "transform", "from": "equation_partial", "to": "equation_final", "animation": "matching_tex", "runTime": 0.8 },
              { "type": "show", "targets": ["result_card", "takeaway"], "animation": "fade_in", "runTime": 0.7, "stagger": 0.12 }
            ],
            "holdSeconds": 0.5
          }
        ],
        "continuity": {
          "keep": ["equation_final", "result_card"]
        }
      }
    }
  ]
}
