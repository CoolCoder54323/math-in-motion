          { "id": "compare", "narration": "Around and inside are different ideas.", "actions": [{ "type": "show", "targets": ["takeaway"], "animation": "write", "runTime": 0.9 }, { "type": "recipe", "recipe": "celebrate", "targets": ["guide"], "runTime": 0.6 }], "holdSeconds": 0.9 }
        ]
