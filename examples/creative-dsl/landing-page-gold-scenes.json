{
  "description": "Gold-standard Creative DSL examples based on the landing page prompts. These are intended as prompt exemplars and regression fixtures for engaging Manim scenes.",
  "scenes": [
    {
      "prompt": "Show me how to add fractions with unlike denominators, step by step, using a visual pizza-slice example.",
      "sceneIR": {
        "metadata": {
          "sceneId": "gold_fraction_pizza_addition",
          "role": "worked_example",
          "visualIntent": "A character chef turns two unlike pizza slices into a shared denominator, then combines highlighted pieces.",
          "densityTarget": 0.45,
          "baseClass": "Scene",
          "creativeIntent": {
            "metaphor": "A friendly chef compares two pizzas on a kitchen counter.",
            "reveal": "Slices split into matching eighths before sliding together.",
            "finalFrame": "Two pizzas become one clear equation: 1/2 + 1/4 = 3/4."
          }
        },
        "layout": {
          "safeArea": { "xMin": -6.5, "xMax": 6.5, "yMin": -3.5, "yMax": 3.5 },
          "zones": [
            { "id": "title", "x": 0, "y": 2.8, "width": 11, "height": 0.8, "note": "short title" },
            { "id": "left", "x": -3.4, "y": 0.45, "width": 3.8, "height": 3.6, "note": "first pizza" },
            { "id": "right", "x": 1.6, "y": 0.45, "width": 4.4, "height": 3.6, "note": "second and combined pizza" },
            { "id": "guide", "x": -5.4, "y": -2.1, "width": 2.0, "height": 1.8, "note": "character lane" },
            { "id": "footer", "x": 1.0, "y": -2.7, "width": 8.5, "height": 0.9, "note": "equation lane" }
          ],
          "continuitySlots": ["sum_equation"]
        },
        "objects": [
          {
            "id": "chef",
            "kind": "compound.character",
            "role": "guide",
            "anchor": { "zone": "guide", "align": "center" },
            "props": { "shape": "star", "expression": "curious", "pose": "point", "bodyColor": "SUN", "accentColor": "PINK", "label": "same-size slices!" },
            "zIndex": 8
          },
          {
            "id": "half_pizza",
            "kind": "compound.split_shape",
            "role": "first_addend",
            "anchor": { "zone": "left", "align": "center", "dy": 0.25 },
            "props": { "shape": "circle", "parts": 2, "highlighted": 1, "labelTex": "\\\\frac{1}{2}", "fillColor": "PINK", "radius": 1.2 },
            "relatedTo": ["chef"],
            "zIndex": 2
          },
          {
            "id": "quarter_pizza",
            "kind": "compound.split_shape",
            "role": "second_addend",
            "anchor": { "zone": "right", "align": "left", "dx": 0.8, "dy": 0.25 },
            "props": { "shape": "circle", "parts": 4, "highlighted": 1, "labelTex": "\\\\frac{1}{4}", "fillColor": "SKY", "radius": 1.2 },
            "relatedTo": ["chef"],
            "zIndex": 2
          },
          {
            "id": "eighths_pizza",
            "kind": "compound.split_shape",
            "role": "common_denominator",
            "anchor": { "zone": "right", "align": "right", "dx": -0.6, "dy": 0.25 },
            "props": { "shape": "circle", "parts": 8, "highlighted": 6, "labelTex": "\\\\frac{6}{8}=\\\\frac{3}{4}", "fillColor": "GRASS", "radius": 1.2 },
            "relatedTo": ["half_pizza", "quarter_pizza"],
            "zIndex": 3
          },
          {
            "id": "sum_equation",
            "kind": "compound.equation_ladder",
            "role": "equation_reveal",
            "anchor": { "zone": "footer", "align": "center" },
            "props": { "steps": ["\\\\frac{1}{2}+\\\\frac{1}{4}", "\\\\frac{2}{4}+\\\\frac{1}{4}", "\\\\frac{3}{4}"], "scale": 0.9 },
            "zIndex": 6
          }
        ],
        "beats": [
          { "id": "meet_chef", "narration": "Our guide starts with two pizzas cut differently.", "actions": [{ "type": "show", "targets": ["chef", "half_pizza", "quarter_pizza"], "animation": "fade_in", "runTime": 1.0, "stagger": 0.12 }], "holdSeconds": 0.3 },
          { "id": "same_slices", "narration": "To add them, the slices need the same size.", "actions": [{ "type": "recipe", "recipe": "point", "targets": ["chef"], "runTime": 0.5 }, { "type": "recipe", "recipe": "split", "targets": ["half_pizza", "quarter_pizza"], "runTime": 0.8 }], "holdSeconds": 0.2 },
          { "id": "reveal_eighths", "narration": "Both pizzas can be seen as eighths.", "actions": [{ "type": "show", "targets": ["eighths_pizza"], "animation": "create", "runTime": 1.0 }, { "type": "recipe", "recipe": "shade", "targets": ["eighths_pizza"], "props": { "color": "GRASS" }, "runTime": 0.6 }], "holdSeconds": 0.4 },
          { "id": "equation_lands", "narration": "Now the addition is visible.", "actions": [{ "type": "show", "targets": ["sum_equation"], "animation": "write", "runTime": 1.0 }, { "type": "recipe", "recipe": "celebrate", "targets": ["chef"], "runTime": 0.6 }], "holdSeconds": 0.8 }
        ],
        "continuity": { "keep": ["sum_equation"] }
      }
    },
    {
