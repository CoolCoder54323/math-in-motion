          { "id": "hundreds", "kind": "compound.grid_fill", "role": "hundreds_blocks", "anchor": { "zone": "left", "align": "center", "dy": 0.2 }, "props": { "rows": 10, "cols": 10, "highlighted": 100, "cellSize": 0.17, "fillColor": "SKY", "label": "2 hundreds" }, "zIndex": 2 },
