          { "id": "ones_land", "narration": "The 3 tells us three ones.", "actions": [{ "type": "recipe", "recipe": "count_in", "targets": ["ones"], "runTime": 0.7 }], "holdSeconds": 0.3 },
          { "id": "expanded_form", "narration": "Together, they build 243.", "actions": [{ "type": "show", "targets": ["number"], "animation": "write", "runTime": 0.9 }, { "type": "recipe", "recipe": "celebrate", "targets": ["builder"], "runTime": 0.6 }], "holdSeconds": 0.8 }
        ]
      }
