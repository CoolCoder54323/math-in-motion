    {
      "prompt": "Explain how to convert a fraction into a percentage for 5th-grade students in an intuitive way.",
      "sceneIR": {
        "metadata": {
          "sceneId": "gold_fraction_to_percent_meter",
          "role": "synthesize",
          "visualIntent": "A percentage meter fills from 3/5 to 60 out of 100 squares with a character announcer.",
          "densityTarget": 0.46,
          "baseClass": "Scene",
          "creativeIntent": {
            "metaphor": "A game meter charges from a fraction to a percent.",
            "reveal": "Three of five bars stretch into sixty of one hundred squares.",
            "finalFrame": "3/5 = 60/100 = 60%."
          }
        },
        "layout": {
          "safeArea": { "xMin": -6.5, "xMax": 6.5, "yMin": -3.5, "yMax": 3.5 },
          "zones": [
            { "id": "title", "x": 0, "y": 2.8, "width": 11, "height": 0.8, "note": "title" },
            { "id": "left", "x": -4.2, "y": 0.3, "width": 3.0, "height": 3.6, "note": "fraction" },
            { "id": "hero", "x": 0.5, "y": 0.3, "width": 5.0, "height": 3.8, "note": "percent grid" },
            { "id": "right", "x": 4.9, "y": -1.5, "width": 2.0, "height": 1.8, "note": "announcer" },
