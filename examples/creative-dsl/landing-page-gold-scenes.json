          ]
        },
        "objects": [
          { "id": "announcer", "kind": "compound.character", "role": "guide", "anchor": { "zone": "right", "align": "center" }, "props": { "shape": "star", "expression": "surprised", "pose": "celebrate", "bodyColor": "PINK", "label": "percent!" }, "zIndex": 8 },
          { "id": "fraction_bars", "kind": "compound.grid_fill", "role": "fraction_model", "anchor": { "zone": "left", "align": "center" }, "props": { "rows": 1, "cols": 5, "highlighted": 3, "cellSize": 0.68, "fillColor": "SKY", "label": "3 out of 5" }, "zIndex": 2 },
          { "id": "percent_grid", "kind": "compound.percent_grid", "role": "percent_model", "anchor": { "zone": "hero", "align": "center" }, "props": { "highlighted": 60, "cellSize": 0.28 }, "zIndex": 2 },
          { "id": "equation", "kind": "compound.equation_ladder", "role": "conversion", "anchor": { "zone": "footer", "align": "center" }, "props": { "steps": ["\\\\frac{3}{5}=\\\\frac{60}{100}", "60 out of 100 = 60%"], "scale": 0.78 }, "zIndex": 6 }
        ],
        "beats": [
          { "id": "show_fraction", "narration": "Start with three out of five equal parts.", "actions": [{ "type": "show", "targets": ["announcer", "fraction_bars"], "animation": "fade_in", "runTime": 0.8, "stagger": 0.12 }], "holdSeconds": 0.3 },
          { "id": "scale_to_100", "narration": "Percent means out of one hundred.", "actions": [{ "type": "show", "targets": ["percent_grid"], "animation": "create", "runTime": 1.0 }, { "type": "recipe", "recipe": "shade", "targets": ["percent_grid"], "props": { "color": "SKY" }, "runTime": 0.6 }], "holdSeconds": 0.4 },
          { "id": "equation_reveal", "narration": "Three fifths is the same as sixty hundredths.", "actions": [{ "type": "show", "targets": ["equation"], "animation": "write", "runTime": 1.0 }], "holdSeconds": 0.4 },
          { "id": "celebrate_percent", "narration": "So three fifths is sixty percent.", "actions": [{ "type": "recipe", "recipe": "celebrate", "targets": ["announcer"], "runTime": 0.7 }, { "type": "emphasize", "targets": ["equation"], "animation": "circumscribe", "runTime": 0.7 }], "holdSeconds": 0.8 }
