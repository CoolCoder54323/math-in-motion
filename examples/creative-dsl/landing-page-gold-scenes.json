          "visualIntent": "A garden guide traces the fence for perimeter and paints square tiles for area.",
          "densityTarget": 0.5,
          "baseClass": "Scene",
          "creativeIntent": {
            "metaphor": "A garden has a fence around it and soil tiles inside it.",
            "reveal": "The outline glows first, then the inside fills with tiles.",
            "finalFrame": "Perimeter is around; area is inside."
          }
        },
        "layout": {
          "safeArea": { "xMin": -6.5, "xMax": 6.5, "yMin": -3.5, "yMax": 3.5 },
          "zones": [
            { "id": "title", "x": 0, "y": 2.8, "width": 11, "height": 0.8, "note": "title" },
            { "id": "hero", "x": 0, "y": 0.4, "width": 7.0, "height": 3.8, "note": "garden" },
            { "id": "left", "x": -4.9, "y": -1.7, "width": 2.0, "height": 1.7, "note": "guide" },
            { "id": "footer", "x": 0, "y": -2.75, "width": 10.5, "height": 0.8, "note": "takeaway" }
          ]
        },
        "objects": [
          { "id": "guide", "kind": "compound.character", "role": "garden_guide", "anchor": { "zone": "left", "align": "center" }, "props": { "shape": "star", "expression": "thinking", "pose": "point", "bodyColor": "GRASS", "label": "around or inside?" }, "zIndex": 8 },
          { "id": "fence", "kind": "compound.trace_path", "role": "perimeter", "anchor": { "zone": "hero", "align": "center", "dy": 0.25 }, "props": { "width": 4.8, "height": 2.5, "strokeColor": "ORANGE", "fillColor": "GRASS", "fillOpacity": 0.12, "label": "perimeter = fence around" }, "zIndex": 2 },
          { "id": "soil_tiles", "kind": "compound.grid_fill", "role": "area", "anchor": { "zone": "hero", "align": "center", "dy": 0.35 }, "props": { "rows": 4, "cols": 6, "highlighted": 24, "cellSize": 0.34, "fillColor": "GRASS", "label": "area = 24 square meters" }, "relatedTo": ["fence"], "zIndex": 3 },
          { "id": "takeaway", "kind": "compound.equation_ladder", "role": "takeaway", "anchor": { "zone": "footer", "align": "center" }, "props": { "steps": ["Perimeter: distance around", "Area: space inside"], "scale": 0.75 }, "zIndex": 6 }
        ],
        "beats": [
          { "id": "garden_question", "narration": "A garden has two different measurements.", "actions": [{ "type": "show", "targets": ["guide", "fence"], "animation": "fade_in", "runTime": 0.9, "stagger": 0.1 }], "holdSeconds": 0.3 },
          { "id": "trace_fence", "narration": "Perimeter follows the fence around the outside.", "actions": [{ "type": "recipe", "recipe": "trace", "targets": ["fence"], "runTime": 1.2 }, { "type": "recipe", "recipe": "point", "targets": ["guide"], "runTime": 0.5 }], "holdSeconds": 0.4 },
