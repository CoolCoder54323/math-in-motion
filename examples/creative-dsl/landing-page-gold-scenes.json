            { "id": "footer", "x": 0, "y": -2.7, "width": 11, "height": 0.9, "note": "equation" }
          ]
        },
        "objects": [
          { "id": "cashier", "kind": "compound.character", "role": "guide", "anchor": { "zone": "right", "align": "center" }, "props": { "shape": "circle", "expression": "curious", "pose": "point", "bodyColor": "ORANGE", "label": "split the combo" }, "zIndex": 9 },
          { "id": "combos", "kind": "compound.grouped_dots", "role": "combo_groups", "anchor": { "zone": "hero", "align": "center", "dy": 0.45 }, "props": { "groups": 3, "perGroup": 6, "colors": ["SUN", "SKY", "SUN"], "dotRadius": 0.09, "spacing": 0.12, "groupSpacing": 0.42, "label": "3 bags of (4 + 2)" }, "zIndex": 2 },
          { "id": "split_equation", "kind": "compound.equation_ladder", "role": "distributed_equation", "anchor": { "zone": "footer", "align": "center" }, "props": { "steps": ["3(4+2)", "3\\\\times4 + 3\\\\times2", "12 + 6 = 18"], "scale": 0.82 }, "zIndex": 5 }
